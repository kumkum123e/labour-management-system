PORT=5000
CLIENT_URL=http://localhost:3000

# Same settings as Azure Data Studio
DB_SERVER=localhost\SQLEXPRESS
DB_DATABASE=LabourManagementSystem

JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRES_IN=7d

# Admin Access Restriction Configuration
# Allowed modes: 
# - 'private' (default): Allow localhost & private subnets (10.x.x.x, 192.168.x.x, etc.)
# - 'local': Allow localhost / loopback ONLY (127.0.0.1, ::1, own server)
# - 'whitelisted': Allow localhost / loopback AND explicit IPs listed in ADMIN_WHITELISTED_IPS
ADMIN_ACCESS_MODE=private
ADMIN_WHITELISTED_IPS=127.0.0.1,::1

