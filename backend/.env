PORT=5000
CLIENT_URL=http://localhost:3000

# Same as Azure Data Studio connection
DB_SERVER=localhost\SQLEXPRESS
DB_DATABASE=LabourManagementSystem

# Backup folder (SQL Server service account needs Modify permission here)
SQL_BACKUP_PATH=./backups/sql

JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Admin Access Restriction Configuration
# Allowed modes: 'private' (default), 'local', 'whitelisted'
ADMIN_ACCESS_MODE=private
ADMIN_WHITELISTED_IPS=127.0.0.1,::1

