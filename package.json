{
  "name": "labour-management-system",
  "version": "1.0.0",
  "description": "Labour Management System — backend + frontend",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm start --prefix frontend",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev --prefix backend\" \"npm start --prefix frontend\"",
