    "frontend": "npm start --prefix frontend",
    "start:backend": "npm start --prefix backend",
    "check:db": "npm run check:db --prefix backend",
    "test:api": "npm run test:api --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
